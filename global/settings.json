{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(just *)",
      "Bash(uv *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pytest *)",
      "Bash(golangci-lint *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(chub *)"
